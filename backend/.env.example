# ============ DATABASE (PostgreSQL) ============
# Miễn phí vĩnh viễn: tạo ở https://neon.tech rồi dán connection string vào đây.
# Dùng CHUNG cho cả local dev và production (mỗi nơi 1 URL/branch riêng nếu muốn).
DATABASE_URL="postgresql://user:password@ep-xxx.aws.neon.tech/memorymakers?sslmode=require"

# ============ AUTH ============
JWT_SECRET="doi-chuoi-bi-mat-nay-trong-production"
JWT_EXPIRES_IN="7d"

# ============ LƯU ẢNH: Cloudinary (miễn phí) ============
# Tạo tài khoản https://cloudinary.com -> Dashboard copy 3 giá trị.
# Nếu để TRỐNG cả 3 -> ảnh sẽ lưu vào đĩa (chỉ hợp local dev / server có volume).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# (hoặc dùng 1 dòng duy nhất thay cho 3 dòng trên)
# CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# ============ OTP / SMS ============
# Để trống ở dev: OTP in ra console + trả trong response (devOtp).
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# ============ SERVER ============
PORT=5000
FRONTEND_ORIGIN="http://localhost:3000"
# URL công khai của backend (chỉ dùng khi lưu ảnh vào ĐĨA, không dùng Cloudinary)
PUBLIC_URL="http://localhost:5000"
# Thư mục lưu ảnh khi không dùng Cloudinary (deploy có volume: /data/uploads)
# UPLOAD_DIR="/data/uploads"

# ============ TÀI KHOẢN ADMIN (tự tạo khi khởi động) — ĐỔI trước khi chạy thật ============
OWNER_EMAIL=owner@memorymakers.com
OWNER_PASSWORD=ChangeMe123!
OWNER_NAME=Chủ shop
OWNER_PHONE=0900000000
