# --- Database ---
# SQLite cho dev. Production: đổi sang PostgreSQL, vd:
# DATABASE_URL="postgresql://user:pass@localhost:5432/memorymakers"
DATABASE_URL="file:./dev.db"

# --- Auth ---
JWT_SECRET="doi-chuoi-bi-mat-nay-trong-production"
JWT_EXPIRES_IN="7d"

# --- OTP / SMS ---
# Để trống ở dev: OTP sẽ được in ra console và trả về trong response (devOtp).
# Production: điền credentials Twilio (hoặc nhà cung cấp SMS khác) rồi bật SMS_ENABLED=true
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# --- Server ---
PORT=5000
FRONTEND_ORIGIN="http://localhost:3000"

# --- Tài khoản admin chính (seed) — ĐỔI trước khi chạy thật ---
OWNER_EMAIL="owner@memorymakers.com"
OWNER_PASSWORD="ChangeMe123!"
OWNER_NAME="Chủ shop"
OWNER_PHONE="0900000000"

# URL công khai của backend để dựng link ảnh upload (đổi khi deploy, vd https://api.tenmien.com)
PUBLIC_URL="http://localhost:5000"
